       IDENTIFICATION DIVISION.
       PROGRAM-ID. EMPUPD2.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01  WS-DBDATA.
           05  WS-EMPNO              PIC X(6).
           05  WS-FIRSTNME           PIC X(12).
           05  WS-MIDINIT            PIC X.
           05  WS-LASTNAME           PIC X(15).
           05  WS-WORKDEPT           PIC X(3).
           05  WS-PHONENO            PIC X(4).
           05  WS-HIREDATE           PIC X(10).
           05  WS-JOB                PIC X(8).
           05  WS-EDLEVEL            PIC S9(4) USAGE COMP.
           05  WS-SEX                PIC X.
           05  WS-BIRTHDATE          PIC X(10).
           05  WS-SALARY-PD          PIC S9(7)V9(2) USAGE COMP-3.
           05  WS-BONUS-PD           PIC S9(7)V9(2) USAGE COMP-3.
           05  WS-COMM-PD            PIC S9(7)V9(2) USAGE COMP-3.
           05  WS-SUCCESS            PIC X.
           05  WS-SQL-CODE           PIC S9(9) COMP-4.
           05  WS-SQL-STATE          PIC X(5).
           EXEC SQL INCLUDE SQLCA END-EXEC.
           EXEC SQL INCLUDE MYEMP END-EXEC.
       LINKAGE SECTION.
       01  DFHCOMMAREA.
            COPY UPDCP.
      *
       PROCEDURE DIVISION USING DFHCOMMAREA.
      *
       000-MAIN.
           PERFORM 1000-UPDATE-RECORD
           PERFORM 2000-GET-ME-OUT-OF-HERE.
      *
       1000-UPDATE-RECORD.
           MOVE COMM-EMPNO TO WS-EMPNO
           MOVE COMM-FIRSTNME TO WS-FIRSTNME
           MOVE COMM-MIDINIT TO WS-MIDINIT
           MOVE COMM-LASTNAME TO WS-LASTNAME
           MOVE COMM-WORKDEPT TO WS-WORKDEPT
           MOVE COMM-PHONENO TO WS-PHONENO
           MOVE COMM-HIREDATE TO WS-HIREDATE
           MOVE COMM-JOB TO WS-JOB
           MOVE COMM-EDLEVEL TO WS-EDLEVEL
           MOVE COMM-SEX TO WS-SEX
           MOVE COMM-BIRTHDATE TO WS-BIRTHDATE
           MOVE COMM-SALARY-PD TO WS-SALARY-PD
           MOVE COMM-BONUS-PD TO WS-BONUS-PD
           MOVE COMM-COMM-PD TO WS-COMM-PD
      *    EXEC SQL
      *        INSERT INTO IBMUSER.MY_EMP (EMPNO, FIRSTNME, MIDINIT,
      *          LASTNAME, WORKDEPT, PHONENO, HIREDATE, JOB, EDLEVEL,
      *          SEX, BIRTHDATE, SALARY, BONUS, COMM)
      *        VALUES (:WS-EMPNO, :WS-FIRSTNME, :WS-MIDINIT,
      *          :WS-LASTNAME, :WS-WORKDEPT, :WS-PHONENO,
      *          :WS-HIREDATE, :WS-JOB, :WS-EDLEVEL, :WS-SEX,
      *          :WS-BIRTHDATE, :WS-SALARY-PD, :WS-BONUS-PD,
      *          :WS-COMM-PD)
      *    END-EXEC
           EXEC SQL
               UPDATE IBMUSER.MY_EMP
                  SET EMPNO = :WS-EMPNO,
                      FIRSTNME = :WS-FIRSTNME,
                      MIDINIT = :WS-MIDINIT,
                      LASTNAME = :WS-LASTNAME,
                      WORKDEPT = :WS-WORKDEPT,
                      PHONENO = :WS-PHONENO,
                      HIREDATE = :WS-HIREDATE,
                      JOB = :WS-JOB,
                      EDLEVEL = :WS-EDLEVEL,
                      SEX = :WS-SEX,
                      BIRTHDATE = :WS-BIRTHDATE,
                      SALARY = :WS-SALARY-PD,
                      BONUS = :WS-BONUS-PD,
                      COMM = :WS-COMM-PD
               WHERE EMPNO = :WS-EMPNO
           END-EXEC
           IF SQLSTATE = '00000'
               MOVE 'Y' TO COMM-SUCCESS
           ELSE
               MOVE 'N' TO COMM-SUCCESS
               MOVE SQLCODE TO COMM-SQL-CODE
               MOVE SQLSTATE TO COMM-SQL-STATE
           END-IF.
      *
       2000-GET-ME-OUT-OF-HERE.
           EXEC CICS
              RETURN
           END-EXEC.
