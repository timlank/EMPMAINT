       IDENTIFICATION DIVISION.
       PROGRAM-ID. EMPUPD.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01  SWITCHES.
           05  VALID-DATA-SW        PIC X     VALUE 'Y'.
               88  VALID-DATA                 VALUE 'Y'.
       01  FLAGS.
           05  SEND-FLAG            PIC X.
               88  SEND-ERASE                 VALUE '1'.
               88  SEND-DATAONLY              VALUE '2'.
               88  SEND-DATAONLY-ALARM        VALUE '3'.
       01  COMMUNICATION-AREA.
           05  DI-STATUS            PIC X(15).
       01  WS-RECSEL                PIC X(6).
       01  WS-DBDATA.
           05  WS-EMPNO             PIC X(6).
           05  WS-FIRSTNME          PIC X(12).
           05  WS-MIDINIT           PIC X.
           05  WS-LASTNAME          PIC X(15).
           05  WS-WORKDEPT          PIC X(3).
           05  WS-PHONENO           PIC X(4).
           05  WS-HIREDATE          PIC X(10).
           05  WS-JOB               PIC X(8).
           05  WS-EDLEVEL           PIC X(4).
           05  WS-EDLEVEL-PD        PIC S9(4) USAGE COMP.
           05  WS-SEX               PIC X.
           05  WS-BIRTHDATE         PIC X(10).
           05  WS-SALARY            PIC X(10).
           05  WS-BONUS             PIC X(10).
           05  WS-COMM              PIC X(10).
           05  WS-SALARY-PD         PIC S9(7)V9(2) USAGE COMP-3.
           05  WS-BONUS-PD          PIC S9(7)V9(2) USAGE COMP-3.
           05  WS-COMM-PD           PIC S9(7)V9(2) USAGE COMP-3.
           05  WS-SAL1-SRC          PIC X(7).
           05  WS-BON1-SRC          PIC X(7).
           05  WS-COM1-SRC          PIC X(7).
           05  WS-SAL2-SRC          PIC X(2).
           05  WS-BON2-SRC          PIC X(2).
           05  WS-COM2-SRC          PIC X(2).
           05  WS-EDITED-SALARY     PIC 9999999.99.
           05  WS-EDITED-BONUS      PIC 9999999.99.
           05  WS-EDITED-COMM       PIC 9999999.99.
       01  SUBPGM-PARMS.
           05  SUBPGM-EMPNO             PIC X(6).
           05  SUBPGM-FIRSTNME          PIC X(12).
           05  SUBPGM-MIDINIT           PIC X.
           05  SUBPGM-LASTNAME          PIC X(15).
           05  SUBPGM-WORKDEPT          PIC X(3).
           05  SUBPGM-PHONENO           PIC X(4).
           05  SUBPGM-HIREDATE          PIC X(10).
           05  SUBPGM-JOB               PIC X(8).
           05  SUBPGM-EDLEVEL-PD        PIC S9(4) USAGE COMP.
           05  SUBPGM-SEX               PIC X.
           05  SUBPGM-BIRTHDATE         PIC X(10).
           05  SUBPGM-SALARY-PD         PIC S9(7)V9(2) USAGE COMP-3.
           05  SUBPGM-BONUS-PD          PIC S9(7)V9(2) USAGE COMP-3.
           05  SUBPGM-COMM-PD           PIC S9(7)V9(2) USAGE COMP-3.
           05  SUBPGM-SUCCESS           PIC X.
           05  SUBPGM-SQL-CODE          PIC S9(9) COMP-4.
           05  SUBPGM-SQL-STATE         PIC X(5).
           EXEC SQL INCLUDE SQLCA END-EXEC.
           EXEC SQL INCLUDE MYEMP END-EXEC.
       COPY EMPMP3.
       COPY DFHAID.
       COPY ATTR.
       LINKAGE SECTION.
       01  DFHCOMMAREA              PIC X(106).
      *
       PROCEDURE DIVISION.
      *
       0000-PROCESS-EMPLOYEE-CREATE.
           IF EIBCALEN > ZERO
                MOVE DFHCOMMAREA TO COMMUNICATION-AREA
           END-IF.
           EVALUATE TRUE
               WHEN EIBCALEN = ZERO
                   MOVE LOW-VALUE TO EMPMAP3O
                   MOVE 'EMUP'    TO TRANSIDO
                   SET SEND-ERASE TO TRUE
                   PERFORM 1400-SEND-EMPLOYEE-MAP
                   MOVE 'FIRST TIME' TO COMMUNICATION-AREA
               WHEN EIBAID = DFHCLEAR
                   MOVE 'CLEAR HIT' TO COMMUNICATION-AREA
                   MOVE LOW-VALUE TO EMPMAP3O
                   MOVE 'EMUP'    TO TRANSIDO
                   SET SEND-ERASE TO TRUE
                   PERFORM 1400-SEND-EMPLOYEE-MAP
               WHEN EIBAID = DFHPF3 OR DFHPF12
                   EXEC CICS
                      XCTL PROGRAM('EMPMAIN')
                   END-EXEC
               WHEN DI-STATUS = 'READY TO UPDATE'
                   PERFORM 1000-PROCESS-EMPLOYEE-MAP
               WHEN DI-STATUS = 'NEED CLEAR'
                   EXEC CICS
                       RETURN TRANSID('EMUP')
                       COMMAREA(COMMUNICATION-AREA)
                   END-EXEC
               WHEN EIBAID = DFHPA1 OR DFHPA2 OR DFHPA3
                   CONTINUE
               WHEN EIBAID = DFHENTER
                   MOVE DFHCOMMAREA TO COMMUNICATION-AREA
                   IF DI-STATUS = 'NEXT RUN'
                     MOVE 'N' TO VALID-DATA-SW
                   END-IF
                   PERFORM 1050-PROCESS-EMPLOYEE-MAP2
               WHEN OTHER
                   MOVE LOW-VALUE TO EMPMAP3O
                   MOVE 'Invalid key pressed.' TO MSG1O
                   SET SEND-DATAONLY-ALARM TO TRUE
                   MOVE SPACES TO EMPNOO
                   PERFORM 1400-SEND-EMPLOYEE-MAP
           END-EVALUATE.
           EXEC CICS
              RETURN TRANSID('EMUP')
                  COMMAREA(COMMUNICATION-AREA)
           END-EXEC.
      *
       1000-PROCESS-EMPLOYEE-MAP.
           MOVE DFHCOMMAREA TO COMMUNICATION-AREA
           MOVE EMPNOO TO WS-EMPNO
           MOVE FIRSTNMO TO WS-FIRSTNME
           MOVE MIDINITO TO WS-MIDINIT
           MOVE LASTNAMO TO WS-LASTNAME
           MOVE WORKDEPO TO WS-WORKDEPT
           MOVE PHONENOO TO WS-PHONENO
           MOVE HIREDATO TO WS-HIREDATE
           MOVE JOBO TO WS-JOB
           MOVE EDLEVELO TO WS-EDLEVEL
           MOVE SEXO TO WS-SEX
           MOVE BIRTHDAO TO WS-BIRTHDATE
           MOVE SAL1O TO WS-SAL1-SRC
           MOVE SAL2O TO WS-SAL2-SRC
           MOVE BON1O TO WS-BON1-SRC
           MOVE BON2O TO WS-BON2-SRC
           MOVE COM1O TO WS-COM1-SRC
           MOVE COM2O TO WS-COM2-SRC
           PERFORM 1100-RECEIVE-EMPLOYEE-MAP
           PERFORM 1200-EDIT-EMPLOYEE-DATA
           IF VALID-DATA
               STRING
                   WS-SAL1-SRC DELIMITED BY SIZE
                   '.' DELIMITED BY SIZE
                   WS-SAL2-SRC DELIMITED BY SIZE
                   INTO WS-SALARY
               END-STRING
               STRING
                   WS-BON1-SRC DELIMITED BY SIZE
                   '.' DELIMITED BY SIZE
                   WS-BON2-SRC DELIMITED BY SIZE
                   INTO WS-BONUS
               END-STRING
               STRING
                   WS-COM1-SRC DELIMITED BY SIZE
                   '.' DELIMITED BY SIZE
                   WS-COM2-SRC DELIMITED BY SIZE
                   INTO WS-COMM
               END-STRING
               COMPUTE WS-EDLEVEL-PD = FUNCTION NUMVAL(WS-EDLEVEL)
               COMPUTE WS-SALARY-PD = FUNCTION NUMVAL(WS-SALARY)
               COMPUTE WS-BONUS-PD = FUNCTION NUMVAL(WS-BONUS)
               COMPUTE WS-COMM-PD = FUNCTION NUMVAL(WS-COMM)
               MOVE WS-EMPNO TO SUBPGM-EMPNO
               MOVE WS-FIRSTNME TO SUBPGM-FIRSTNME
               MOVE WS-MIDINIT TO SUBPGM-MIDINIT
               MOVE WS-LASTNAME TO SUBPGM-LASTNAME
               MOVE WS-WORKDEPT TO SUBPGM-WORKDEPT
               MOVE WS-PHONENO TO SUBPGM-PHONENO
               MOVE WS-HIREDATE TO SUBPGM-HIREDATE
               MOVE WS-JOB TO SUBPGM-JOB
               MOVE WS-EDLEVEL-PD TO SUBPGM-EDLEVEL-PD
               MOVE WS-SEX TO SUBPGM-SEX
               MOVE WS-BIRTHDATE TO SUBPGM-BIRTHDATE
               MOVE WS-SALARY-PD TO SUBPGM-SALARY-PD
               MOVE WS-BONUS-PD TO SUBPGM-BONUS-PD
               MOVE WS-COMM-PD TO SUBPGM-COMM-PD
               PERFORM 1300-PUT-EMPLOYEE-RECORD
           END-IF
               MOVE 'NEED CLEAR' TO DI-STATUS
               SET SEND-DATAONLY-ALARM TO TRUE
               PERFORM 1400-SEND-EMPLOYEE-MAP.
      *
       1050-PROCESS-EMPLOYEE-MAP2.
           PERFORM 1100-RECEIVE-EMPLOYEE-MAP
           PERFORM 1250-EDIT-EMPLOYEE-DATA2
           IF VALID-DATA
               PERFORM 1350-GET-EMPLOYEE-DATA2
           END-IF
           IF VALID-DATA
               SET SEND-DATAONLY TO TRUE
               PERFORM 1400-SEND-EMPLOYEE-MAP
           ELSE
               SET SEND-DATAONLY-ALARM TO TRUE
               PERFORM 1400-SEND-EMPLOYEE-MAP
           END-IF.
      *
       1100-RECEIVE-EMPLOYEE-MAP.
           EXEC CICS
               RECEIVE MAP('EMPMAP3')
                       MAPSET('EMPMP3')
                       INTO(EMPMAP3I)
           END-EXEC
           IF FIRSTNML NOT EQUAL 0
             MOVE FIRSTNMO TO WS-FIRSTNME
           END-IF
           IF MIDINITL NOT EQUAL 0
             MOVE MIDINITO TO WS-MIDINIT
           END-IF
           IF LASTNAML NOT EQUAL 0
             MOVE LASTNAMO TO WS-LASTNAME
           END-IF
           IF WORKDEPL NOT EQUAL 0
             MOVE WORKDEPO TO WS-WORKDEPT
           END-IF
           IF PHONENOL NOT EQUAL 0
             MOVE PHONENOO TO WS-PHONENO
           END-IF
           IF HIREDATL NOT EQUAL 0
             MOVE HIREDATO TO WS-HIREDATE
           END-IF
           IF JOBL NOT EQUAL 0
             MOVE JOBO TO WS-JOB
           END-IF
           IF EDLEVELL NOT EQUAL 0
             MOVE EDLEVELO TO WS-EDLEVEL
           END-IF
           IF SEXL NOT EQUAL 0
             MOVE SEXO TO WS-SEX
           END-IF
           IF BIRTHDAL NOT EQUAL 0
             MOVE BIRTHDAO TO WS-BIRTHDATE
           END-IF
           IF SAL1L NOT EQUAL 0
             MOVE SAL1O TO WS-SAL1-SRC
           END-IF
           IF SAL2L NOT EQUAL 0
             MOVE SAL2O TO WS-SAL2-SRC
           END-IF
           IF BON1L NOT EQUAL 0
             MOVE BON1O TO WS-BON1-SRC
           END-IF
           IF BON2L NOT EQUAL 0
             MOVE BON2O TO WS-BON2-SRC
           END-IF
           IF COM1L NOT EQUAL 0
             MOVE COM1O TO WS-COM1-SRC
           END-IF
           IF COM2L NOT EQUAL 0
             MOVE COM2O TO WS-COM2-SRC
           END-IF.
      *
       1200-EDIT-EMPLOYEE-DATA.
           IF COM1L = ZERO
             OR COM1I = SPACES
                MOVE 'You must enter a commission - PRESS CLEAR TO CONTI
      -             'NUE' TO MSG1O
                MOVE 'N' TO VALID-DATA-SW
                MOVE 'NEED CLEAR' TO DI-STATUS
           END-IF
           IF WS-COM1-SRC(1:1) IS NUMERIC AND WS-COM1-SRC(2:1)
             IS NUMERIC AND WS-COM1-SRC(3:1) IS NUMERIC AND
             WS-COM1-SRC(4:1) IS NUMERIC AND WS-COM1-SRC(5:1) IS
             NUMERIC AND WS-COM1-SRC(6:1) IS NUMERIC AND
             WS-COM1-SRC(7:1) IS NUMERIC AND WS-COM2-SRC(1:1) IS NUMERIC
             AND WS-COM2-SRC(2:1) IS NUMERIC
                CONTINUE
           ELSE
                 MOVE 'You must only have digits for commission - PRESS
      -            'CLEAR TO TO CONTINUE'
                    TO MSG1O
                 MOVE 'N' TO VALID-DATA-SW
                 MOVE 'NEED CLEAR' TO DI-STATUS
           END-IF
           IF BON1L = ZERO
             OR BON1I = SPACES
                MOVE 'You must enter a bonus - PRESS CLEAR TO CONTINUE'
                     TO MSG1O
                MOVE 'N' TO VALID-DATA-SW
                MOVE 'NEED CLEAR' TO DI-STATUS
           END-IF
           IF WS-BON1-SRC(1:1) IS NUMERIC AND WS-BON1-SRC(2:1)
             IS NUMERIC AND WS-BON1-SRC(3:1) IS NUMERIC AND
             WS-BON1-SRC(4:1) IS NUMERIC AND WS-BON1-SRC(5:1) IS
             NUMERIC AND WS-BON1-SRC(6:1) IS NUMERIC AND
             WS-BON1-SRC(7:1) IS NUMERIC AND WS-BON2-SRC(1:1) IS NUMERIC
             AND WS-BON2-SRC(2:1) IS NUMERIC
                CONTINUE
           ELSE
                 MOVE 'You must only have digits for bonus - PRESS CLEAR
      -            ' TO CONTINUE'
                    TO MSG1O
                 MOVE 'N' TO VALID-DATA-SW
                 MOVE 'NEED CLEAR' TO DI-STATUS
           END-IF
           IF SAL1L = ZERO
             OR SAL1I = SPACES
                MOVE 'You must enter a salary - PRESS CLEAR TO CONTINUE'
                    TO MSG1O
                MOVE 'N' TO VALID-DATA-SW
                MOVE 'NEED CLEAR' TO DI-STATUS
           END-IF
           IF WS-SAL1-SRC(1:1) IS NUMERIC AND WS-SAL1-SRC(2:1)
             IS NUMERIC AND WS-SAL1-SRC(3:1) IS NUMERIC AND
             WS-SAL1-SRC(4:1) IS NUMERIC AND WS-SAL1-SRC(5:1) IS
             NUMERIC AND WS-SAL1-SRC(6:1) IS NUMERIC AND
             WS-SAL1-SRC(7:1) IS NUMERIC AND WS-SAL2-SRC(1:1) IS NUMERIC
             AND WS-SAL2-SRC(2:1) IS NUMERIC
                CONTINUE
           ELSE
                 MOVE 'You must only have digits for salary - PRESS CLEA
      -            'R TO CONTINUE'
                    TO MSG1O
                 MOVE 'N' TO VALID-DATA-SW
                 MOVE 'NEED CLEAR' TO DI-STATUS
           END-IF
           IF WS-BIRTHDATE(3:1) NOT EQUAL '.' OR WS-BIRTHDATE(6:1)
             NOT EQUAL '.'
               MOVE 'You must format the birthdate with periods - PRESS
      -         'CLEAR TO CONTINUE'
                 TO MSG1O
               MOVE 'N' TO VALID-DATA-SW
               MOVE 'NEED CLEAR' TO DI-STATUS
           END-IF
           IF WS-BIRTHDATE(1:1) IS NUMERIC AND WS-BIRTHDATE(2:1) IS
              NUMERIC AND WS-BIRTHDATE(4:1) IS NUMERIC AND
              WS-BIRTHDATE(5:1) IS NUMERIC AND WS-BIRTHDATE(7:1) IS
              NUMERIC AND WS-BIRTHDATE(8:1) IS NUMERIC AND
              WS-BIRTHDATE(9:1) IS NUMERIC AND WS-BIRTHDATE(10:1) IS
              NUMERIC
                 CONTINUE
              ELSE
                 MOVE 'You must only have digits for birthdate DD MM and
      -            ' YYYY - PRESS CLEAR TO CONTINUE'
                    TO MSG1O
                 MOVE 'N' TO VALID-DATA-SW
                 MOVE 'NEED CLEAR' TO DI-STATUS
              END-IF
           IF EDLEVELL = ZERO
             OR EDLEVELI = SPACES
                MOVE 'You must enter an education level - PRESS CLEAR TO
      -            'CONTINUE' TO MSG1O
                MOVE 'N' TO VALID-DATA-SW
                MOVE 'NEED CLEAR' TO DI-STATUS
           END-IF
           IF WS-EDLEVEL(1:1) IS NUMERIC AND WS-EDLEVEL(2:1)
             IS NUMERIC AND WS-EDLEVEL(3:1) IS NUMERIC AND
             WS-EDLEVEL(4:1) IS NUMERIC
                CONTINUE
           ELSE
                 MOVE 'You must only have digits for education level - P
      -            'RESS CLEAR TO CONTINUE'
                    TO MSG1O
                 MOVE 'N' TO VALID-DATA-SW
                 MOVE 'NEED CLEAR' TO DI-STATUS
              END-IF
           IF WS-HIREDATE(3:1) NOT EQUAL '.' OR WS-HIREDATE(6:1)
             NOT EQUAL '.'
               MOVE 'You must format the hiredate with periods - PRESS C
      -         'LEAR TO CONTINUE'
                 TO MSG1O
               MOVE 'N' TO VALID-DATA-SW
               MOVE 'NEED CLEAR' TO DI-STATUS
           END-IF
           IF WS-HIREDATE(1:1) IS NUMERIC AND WS-HIREDATE(2:1) IS
              NUMERIC AND WS-HIREDATE(4:1) IS NUMERIC AND
              WS-HIREDATE(5:1) IS NUMERIC AND WS-HIREDATE(7:1) IS
              NUMERIC AND WS-HIREDATE(8:1) IS NUMERIC AND
              WS-HIREDATE(9:1) IS NUMERIC AND WS-HIREDATE(10:1) IS
              NUMERIC
                 CONTINUE
              ELSE
                 MOVE 'You must only have digits for hiredate DD MM and
      -            'YYYY - PRESS CLEAR TO CONTINUE'
                    TO MSG1O
                 MOVE 'N' TO VALID-DATA-SW
                 MOVE 'NEED CLEAR' TO DI-STATUS
              END-IF
           IF EMPNOL NOT EQUAL 0 AND
              EMPNOO NOT EQUAL WS-EMPNO
                MOVE 'You cannot change an employee number - PRESS CLEAR
      -              ' TO CONTINUE' TO MSG1O
                MOVE 'N' TO VALID-DATA-SW
                MOVE 'NEED CLEAR' TO DI-STATUS
           END-IF.
      *
       1250-EDIT-EMPLOYEE-DATA2.
           IF EMPNOL = ZERO
             OR EMPNOI = SPACES
                MOVE 'You must enter an employee number' TO MSG1O
                MOVE 'N' TO VALID-DATA-SW
           END-IF.
      *
       1300-PUT-EMPLOYEE-RECORD.
           EXEC CICS LINK
               PROGRAM('EMPUPD2')
               COMMAREA(SUBPGM-PARMS)
               SYNCONRETURN
           END-EXEC
           IF SUBPGM-SUCCESS = 'N'
              MOVE SUBPGM-SQL-CODE TO LASTNAMO
              MOVE SUBPGM-SQL-STATE TO FIRSTNMO
              MOVE 'RECORD UPDATE FAILED - SEE CODES IN FIRSTNAME AND LA
      -       'STAME FIELDS FOR DIAGNOSIS - PRESS CLEAR KEY TO CONTINUE'
              TO MSG1O
           END-IF
           IF SUBPGM-SUCCESS = 'Y'
              MOVE 'RECORD UPDATED SUCCESSFULLY - PRESS CLEAR KEY TO CON
      -           'TINUE'
                  TO MSG1O
              MOVE 'NEXT RUN' TO DI-STATUS
           END-IF.
      *
       1350-GET-EMPLOYEE-DATA2.
           MOVE SPACES TO FIRSTNMO
           MOVE SPACES TO MIDINITO
           MOVE SPACES TO LASTNAMO
           MOVE SPACES TO WORKDEPO
           MOVE SPACES TO PHONENOO
           MOVE SPACES TO HIREDATO
           MOVE SPACES TO JOBO
           MOVE SPACES TO EDLEVELO
           MOVE SPACES TO SEXO
           MOVE SPACES TO BIRTHDAO
           MOVE SPACES TO SAL1O
           MOVE SPACES TO SAL2O
           MOVE SPACES TO BON1O
           MOVE SPACES TO BON2O
           MOVE SPACES TO COM1O
           MOVE SPACES TO COM2O
           MOVE EMPNOI TO WS-RECSEL
           MOVE SPACES TO MYEMPRECORD
           EXEC SQL
               SELECT EMPNO, FIRSTNME, MIDINIT, LASTNAME,
                 WORKDEPT, PHONENO, HIREDATE, JOB, EDLEVEL, SEX,
                 BIRTHDATE, SALARY, BONUS, COMM
               INTO :EMPNO, :FIRSTNME, :MIDINIT, :LASTNAME,
                 :WORKDEPT, :PHONENO, :HIREDATE, :JOB, :EDLEVEL,
                 :SEX, :BIRTHDATE, :SALARY, :BONUS, :COMM
               FROM IBMUSER.MY_EMP
               WHERE EMPNO = :WS-RECSEL
           END-EXEC
           IF SQLSTATE = '00000'
               MOVE EMPNO             TO EMPNOO
               MOVE FIRSTNME-TEXT     TO FIRSTNMO
               MOVE MIDINIT           TO MIDINITO
               MOVE LASTNAME-TEXT     TO LASTNAMO
               MOVE WORKDEPT          TO WORKDEPO
               MOVE PHONENO           TO PHONENOO
               MOVE HIREDATE          TO HIREDATO
               MOVE JOB               TO JOBO
               MOVE EDLEVEL           TO EDLEVELO
               MOVE SEX               TO SEXO
               MOVE BIRTHDATE         TO BIRTHDAO
               MOVE SALARY            TO WS-EDITED-SALARY
               MOVE BONUS             TO WS-EDITED-BONUS
               MOVE COMM              TO WS-EDITED-COMM
               MOVE WS-EDITED-SALARY  TO WS-SALARY
               MOVE WS-EDITED-BONUS   TO WS-BONUS
               MOVE WS-EDITED-COMM    TO WS-COMM
               UNSTRING WS-SALARY DELIMITED BY '.'
                  INTO SAL1O
                       SAL2O
               END-UNSTRING
               UNSTRING WS-BONUS DELIMITED BY '.'
                  INTO BON1O
                       BON2O
               END-UNSTRING
               UNSTRING WS-COMM DELIMITED BY '.'
                  INTO COM1O
                       COM2O
               END-UNSTRING
               MOVE 'READY TO UPDATE' TO DI-STATUS
               MOVE SPACES TO MSG1O
           ELSE
               IF SQLSTATE = '02000'
                   MOVE 'RECORD NOT FOUND - PLEASE TRY AGAIN' TO MSG1O
               ELSE
                   MOVE 'ANOTHER ERROR CODE WAS REPORTED' TO MSG1O
               END-IF
               MOVE SPACES TO FIRSTNMO
               MOVE SPACES TO MIDINITO
               MOVE SPACES TO LASTNAMO
               MOVE SPACES TO WORKDEPO
               MOVE SPACES TO PHONENOO
               MOVE SPACES TO HIREDATO
               MOVE SPACES TO JOBO
               MOVE SPACES TO EDLEVELO
               MOVE SPACES TO SEXO
               MOVE SPACES TO BIRTHDAO
           END-IF.
      *
       1400-SEND-EMPLOYEE-MAP.
           EVALUATE TRUE
               WHEN SEND-ERASE
                   EXEC CICS
                       SEND MAP('EMPMAP3')
                            MAPSET('EMPMP3')
                            FROM(EMPMAP3O)
                            CURSOR(183)
                            ERASE
                   END-EXEC
               WHEN SEND-DATAONLY
                   EXEC CICS
                       SEND MAP('EMPMAP3')
                            MAPSET('EMPMP3')
                            FROM(EMPMAP3O)
                            CURSOR(183)
                            DATAONLY
                   END-EXEC
               WHEN SEND-DATAONLY-ALARM
                   EXEC CICS
                       SEND MAP('EMPMAP3')
                            MAPSET('EMPMP3')
                            FROM(EMPMAP3O)
                            CURSOR(183)
                            DATAONLY
                            ALARM
                   END-EXEC
           END-EVALUATE.
      *
