//DB2BIND JOB 'DB2',NOTIFY=&SYSUID,CLASS=A,MSGCLASS=H,
//          MSGLEVEL=(1,1),REGION=0M,LINES=100
//*
//BIND     EXEC PGM=IKJEFT01
//STEPLIB   DD  DISP=SHR,DSN=DBD1.SDSNEXIT
//          DD  DISP=SHR,DSN=DB2V13.SDSNLOAD
//DBRMLIB   DD  DISP=SHR,DSN=IBMUSER.EMPMAINT.DBRMLIB(EMPCRE)
//          DD  DISP=SHR,DSN=IBMUSER.EMPMAINT.DBRMLIB(EMPCRE2)
//          DD  DISP=SHR,DSN=IBMUSER.EMPMAINT.DBRMLIB(EMPDISP)
//          DD  DISP=SHR,DSN=IBMUSER.EMPMAINT.DBRMLIB(EMPUPD)
//          DD  DISP=SHR,DSN=IBMUSER.EMPMAINT.DBRMLIB(EMPUPD2)
//          DD  DISP=SHR,DSN=IBMUSER.EMPMAINT.DBRMLIB(EMPDEL)
//          DD  DISP=SHR,DSN=IBMUSER.EMPMAINT.DBRMLIB(EMPDEL2)
//SYSPRINT  DD  SYSOUT=*
//SYSTSPRT  DD  SYSOUT=*
//SYSUDUMP  DD  SYSOUT=*
//SYSTSIN   DD  *
 DSN S(DBD1)

 BIND PACKAGE(PEMMT) OWNER(IBMUSER)   -
 QUALIFIER(IBMUSER)   -
 MEMBER(EMPCRE2)  -
 ACTION(REPLACE)

 BIND PACKAGE(PEMMT) OWNER(IBMUSER)   -
 QUALIFIER(IBMUSER)   -
 MEMBER(EMPDISP)   -
 ACTION(REPLACE)

 BIND PACKAGE(PEMMT) OWNER(IBMUSER)   -
 QUALIFIER(IBUMSER)   -
 MEMBER(EMPUPD)   -
 ACTION(REPLACE)

 BIND PACKAGE(PEMMT) OWNER(IBMUSER)   -
 QUALIFIER(IBMUSER)   -
 MEMBER(EMPUPD2)   -
 ACTION(REPLACE)

 BIND PACKAGE(PEMMT) OWNER(IBMUSER)   -
 QUALIFIER(IBMUSER)   -
 MEMBER(EMPDEL)   -
 ACTION(REPLACE)

 BIND PACKAGE(PEMMT) OWNER(IBMUSER)   -
 QUALIFIER(IBMUSER)   -
 MEMBER(EMPDEL2)   -
 ACTION(REPLACE)

 BIND PLAN(EMMT)  -
  OWNER(IBMUSER)   -
  ISOLATION(UR)   -
  PKLIST(PEMMT.EMPCRE2, PEMMT.EMPDISP, PEMMT.EMPUPD, PEMMT.EMPUPD2, -
         PEMMT.EMPDEL, PEMMT.EMPDEL2)  -
  ACTION(REPLACE)
 END
