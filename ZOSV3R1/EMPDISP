       IDENTIFICATION DIVISION.
       PROGRAM-ID. EMPDISP.
       ENVIRONMENT DIVISION.
       DATA DIVISION.
       WORKING-STORAGE SECTION.
       01  SWITCHES.
           05  VALID-DATA-SW        PIC X     VALUE 'Y'.
               88  VALID-DATA                 VALUE 'Y'.
       01  FLAGS.
           05  SEND-FLAG            PIC X.
               88  SEND-ERASE                 VALUE '1'.
               88  SEND-DATAONLY              VALUE '2'.
               88  SEND-DATAONLY-ALARM        VALUE '3'.
       01  RESPONSE-CODE            PIC S9(08) COMP.
       01  COMMUNICATION-AREA       PIC X.
       01  WS-MESSAGE               PIC X(15).
       01  WS-SQLCODE-AN            PIC X(9).
       01  WS-RECSEL                PIC X(6).
       01  WS-SQLRET                PIC X(6).
       01  WS-SQLRET-LEN            PIC 9 VALUE 6.
       77  WS-LENGTH                PIC S9(4) COMP.
       01  WS-DBDATA.
           05  WS-EMPNO             PIC X(6).
           05  WS-FIRSTNME          PIC X(12).
           05  WS-MIDINIT           PIC X.
           05  WS-LASTNAME          PIC X(15).
           05  WS-WORKDEPT          PIC X(3).
           05  WS-PHONENO           PIC X(4).
           05  WS-HIREDATE          PIC X(10).
           05  WS-JOB               PIC X(8).
           05  WS-EDLEVEL           PIC S9(4) USAGE COMP.
           05  WS-SEX               PIC X.
           05  WS-BIRTHDATE         PIC X(10).
           05  WS-SALARY            PIC S9(7)V9(2) USAGE COMP-3.
           05  WS-BONUS             PIC S9(7)V9(2) USAGE COMP-3.
           05  WS-COMM              PIC S9(7)V9(2) USAGE COMP-3.
           EXEC SQL INCLUDE SQLCA END-EXEC.
           EXEC SQL INCLUDE MYEMP END-EXEC.
       COPY EMPMP5.
       COPY DFHAID.
       COPY ATTR.
       LINKAGE SECTION.
       01  DFHCOMMAREA              PIC X.
      *
       PROCEDURE DIVISION.
      *
       0000-PROCESS-EMPLOYEE-DISPLAY.
           EVALUATE TRUE
               WHEN EIBCALEN = ZERO
                   MOVE LOW-VALUE TO EMPMAP5O
                   MOVE 'EMDI'    TO TRANSIDO
                   SET SEND-ERASE TO TRUE
                   PERFORM 1400-SEND-EMPLOYEE-MAP
               WHEN EIBAID = DFHCLEAR
                   MOVE LOW-VALUE TO EMPMAP5O
                   MOVE 'EMDI'    TO TRANSIDO
                   SET SEND-ERASE TO TRUE
                   PERFORM 1400-SEND-EMPLOYEE-MAP
               WHEN EIBAID = DFHPA1 OR DFHPA2 OR DFHPA3
                   CONTINUE
               WHEN EIBAID = DFHPF3 OR DFHPF12
                   EXEC CICS
                      XCTL PROGRAM('EMPMAIN')
                   END-EXEC
               WHEN EIBAID = DFHENTER
                   PERFORM 1000-PROCESS-EMPLOYEE-MAP
               WHEN OTHER
                   MOVE LOW-VALUE TO EMPMAP5O
                   MOVE 'Invalid key pressed.' TO MSG1O
                   SET SEND-DATAONLY-ALARM TO TRUE
                   MOVE SPACES TO EMPNOO
                   PERFORM 1400-SEND-EMPLOYEE-MAP
           END-EVALUATE.
           EXEC CICS
               RETURN TRANSID('EMDI')
                      COMMAREA(COMMUNICATION-AREA)
           END-EXEC.
      *
       1000-PROCESS-EMPLOYEE-MAP.
           PERFORM 1100-RECEIVE-EMPLOYEE-MAP
           PERFORM 1200-EDIT-EMPLOYEE-DATA.
           IF VALID-DATA
               PERFORM 1300-GET-EMPLOYEE-RECORD
           END-IF
           IF VALID-DATA
               SET SEND-DATAONLY TO TRUE
               PERFORM 1400-SEND-EMPLOYEE-MAP
           ELSE
               SET SEND-DATAONLY-ALARM TO TRUE
               PERFORM 1400-SEND-EMPLOYEE-MAP
           END-IF.
      *
       1100-RECEIVE-EMPLOYEE-MAP.
           EXEC CICS
               RECEIVE MAP('EMPMAP5')
                       MAPSET('EMPMP5')
                       INTO(EMPMAP5I)
           END-EXEC.
      *
       1200-EDIT-EMPLOYEE-DATA.
           IF EMPNOL = ZERO
             OR EMPNOI = SPACES
                MOVE 'You must enter an employee nubmer' TO MSG1O
                MOVE 'N' TO VALID-DATA-SW
           END-IF.
      *
       1300-GET-EMPLOYEE-RECORD.
           MOVE SPACES TO FIRSTNMO
           MOVE SPACES TO MIDINITO
           MOVE SPACES TO LASTNAMO
           MOVE SPACES TO WORKDEPO
           MOVE SPACES TO PHONENO
           MOVE SPACES TO HIREDATO
           MOVE SPACES TO JOBO
           MOVE SPACES TO EDLEVELO
           MOVE SPACES TO SEXO
           MOVE SPACES TO BIRTHDAO
           MOVE ZEROES TO SALARYO
           MOVE ZEROES TO BONUSO
           MOVE ZEROES TO COMSO
           MOVE EMPNOI TO WS-RECSEL
           MOVE SPACES TO MYEMPRECORD
           EXEC SQL
               SELECT EMPNO, FIRSTNME, MIDINIT, LASTNAME,
                 WORKDEPT, PHONENO, HIREDATE, JOB, EDLEVEL, SEX,
                 BIRTHDATE, SALARY, BONUS, COMM
               INTO :EMPNO, :FIRSTNME, :MIDINIT, :LASTNAME,
                 :WORKDEPT, :PHONENO, :HIREDATE, :JOB, :EDLEVEL,
                 :SEX, :BIRTHDATE, :SALARY, :BONUS, :COMM
               FROM IBMUSER.MY_EMP
               WHERE EMPNO = :WS-RECSEL
           END-EXEC
           IF SQLSTATE = '00000'
               MOVE EMPNO           TO EMPNOO
               MOVE FIRSTNME-TEXT   TO FIRSTNMO
               MOVE MIDINIT         TO MIDINITO
               MOVE LASTNAME-TEXT   TO LASTNAMO
               MOVE WORKDEPT        TO WORKDEPO
               MOVE PHONENO         TO PHONENOO
               MOVE HIREDATE        TO HIREDATO
               MOVE JOB             TO JOBO
               MOVE EDLEVEL         TO EDLEVELO
               MOVE SEX             TO SEXO
               MOVE BIRTHDATE       TO BIRTHDAO
               MOVE SALARY          TO SALARYO
               MOVE BONUS           TO BONUSO
               MOVE COMM            TO COMSO
               MOVE SPACES          TO MSG1O
           ELSE
               IF SQLSTATE = '02000'
                   MOVE 'RECORD NOT FOUND - PLEASE TRY AGAIN' TO MSG1O
               ELSE
                   MOVE 'ANOTHER ERROR CODE WAS REPORTED' TO MSG1O
               END-IF
               MOVE SPACES          TO FIRSTNMO
               MOVE SPACES          TO MIDINITO
               MOVE SPACES          TO LASTNAMO
               MOVE SPACES          TO WORKDEPO
               MOVE SPACES          TO PHONENOO
               MOVE SPACES          TO HIREDATO
               MOVE SPACES          TO JOBO
               MOVE SPACES          TO EDLEVELO
               MOVE SPACES          TO SEXO
               MOVE SPACES          TO BIRTHDAO
               MOVE ZEROES          TO SALARYO
               MOVE ZEROES          TO BONUSO
               MOVE ZEROES          TO COMSO
           END-IF.
      *
       1400-SEND-EMPLOYEE-MAP.
           EVALUATE TRUE
               WHEN SEND-ERASE
                   EXEC CICS
                       SEND MAP('EMPMAP5')
                            MAPSET('EMPMP5')
                            FROM(EMPMAP5O)
                            CURSOR(183)
                            ERASE
                   END-EXEC
               WHEN SEND-DATAONLY
                   EXEC CICS
                       SEND MAP('EMPMAP5')
                            MAPSET('EMPMP5')
                            FROM(EMPMAP5O)
                            CURSOR(183)
                            DATAONLY
                   END-EXEC
               WHEN SEND-DATAONLY-ALARM
                   EXEC CICS
                       SEND MAP('EMPMAP5')
                            MAPSET('EMPMP5')
                            FROM(EMPMAP5O)
                            CURSOR(183)
                            DATAONLY
                            ALARM
                   END-EXEC
           END-EVALUATE.
